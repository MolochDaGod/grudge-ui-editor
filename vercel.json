{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/favicon.ico",  "destination": "/favicon.svg" },
    { "source": "/hotkeys",      "destination": "/hotkeys.html" },
    { "source": "/studio",       "destination": "/studio.html" },
    { "source": "/assets",       "destination": "/assets.html" },
    { "source": "/main-panel",   "destination": "/main-panel.html" },
    { "source": "/equipment",    "destination": "/index.html" },
    { "source": "/((?!hotkeys|studio|assets|main-panel|equipment|favicon|grudge-shell|prim-packs).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ]
}
